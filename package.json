{
  "name": "nova",
  "version": "1.0.0",
  "description": "",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "electron:dev": "concurrently \"node server.js\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "electron-builder --mac",
    "dist": "electron-builder --mac --publish never",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.nova.workspace",
    "productName": "NOVA",
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/assets/icon/nova-icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "electron.js",
      "preload.js",
      "server.js",
      "public/**/*",
      "package.json",
      "walkable_path.json",
      "anchor_config.json",
      "!**/*.md",
      "!**/*.ts",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/spec/**",
      "!**/.github/**",
      "!**/docs/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/.github/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**"
    ],
    "extraResources": [
      {
        "from": "projects",
        "to": "projects"
      }
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
